{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build C++",
            "type": "shell",
            "command": "g++",
            "args": [
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Run C++",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "start",
                "cmd",
                "/c",
                "\"\"${fileDirname}\\${fileBasenameNoExtension}.exe\" & pause\""
            ]
        },
        {
            "label": "Compile Java",
            "type": "shell",
            "command": "javac",
            "args": ["${file}"],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Run Java",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "start",
                "cmd",
                "/c",
                "\"java ${fileBasenameNoExtension} & pause\""
            ],
            "group": "none",
            "problemMatcher": []
        }
    ]
}
